# This environment variable is used in Production and Preview environments to deploy your Convex project
# This variable is not needed in development.
# You can create a Production or Preview deploy key at https://dashboard.convex.dev/project/settings#production-deploy-keys
CONVEX_DEPLOY_KEY=

# Convex
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_FRONTEND_API_URL=

# Brevo (transactional email)
# This variable lives in the Convex deployment (Settings -> Environment Variables), not Next.js.
# It is consumed by convex/emails.ts via process.env inside the Convex runtime.
BREVO_API_KEY=
# Polar (Convex deployment variables, not Next.js)
# These live in the Convex deployment (Settings -> Environment Variables), never in NEXT_PUBLIC_*.
# POLAR_SERVER selects which Polar API server this deployment calls. Must be `sandbox` or `production`.
# Never define both sandbox and production credentials in the same deployment.
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_PRODUCT_ID=
POLAR_SERVER=sandbox|production
# Development/sandbox product: 31b0505a-9ff3-4fa0-a370-adf5e6ad3143
# Polar checkout success URL (Convex deployment variable, not Next.js).
# Full HTTPS URL where Polar redirects the user after a successful checkout (localhost
# allowed for dev). Derived server-side only; never client-supplied. Required to generate
# a checkout URL (the checkout action fails closed if this is missing).
POLAR_CHECKOUT_SUCCESS_URL=