{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "ignorePatterns": [
    "convex/_generated/**",
    "**/*.test.*",
    "**/*.spec.*",
    "**/*.stories.*",
    "components/ui/**"
  ],
  "ignoreDependencies": [
    "@hookform/resolvers",
    "immer",
    "react-hook-form",
    "convex-test",
    "react-doctor",
    "@base-ui/react",
    "class-variance-authority",
    "next-themes",
    "radix-ui"
  ],
  "health": {
    "maxCrap": 250,
    "maxCognitive": 25
  },
  "duplicates": {
    "minOccurrences": 2,
    "mode": "semantic"
  },
  "rules": {
    "unused-dependencies": "error"
  }
}
