{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "ignorePatterns": [
    "convex/_generated/**",
    "**/*.test.*",
    "**/*.spec.*",
    "**/*.stories.*"
  ],
  "ignoreDependencies": [
    "@hookform/resolvers",
    "immer",
    "react-hook-form",
    "convex-test",
    "react-doctor"
  ],
  "health": {
    "maxCrap": 250,
    "maxCognitive": 25
  },
  "duplicates": {
    "minOccurrences": 2,
    "mode": "semantic"
  },
  "rules": {
    "unused-dependencies": "error"
  }
}
